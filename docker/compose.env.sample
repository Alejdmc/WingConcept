# Variables requeridas para docker compose -f docker-compose.yml -f docker-compose.prod.yml
# Copiar a backend/.env y completar con valores reales (nunca commitear)

# Docker Compose lee REDIS_PASSWORD desde este archivo (mismo valor que backend/.env)
REDIS_PASSWORD=GENERAR_CON_openssl_rand_hex_16
SECRET_KEY=GENERAR_CON_openssl_rand_hex_32
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.PROJECT_ID.supabase.co:5432/postgres

ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=WARNING

SUPABASE_URL=https://PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

ALLOWED_HOSTS=wingconcept.com,www.wingconcept.com
ALLOWED_ORIGINS=https://wingconcept.com,https://www.wingconcept.com
FRONTEND_URL=https://wingconcept.com

REQUIRE_EMAIL_VERIFIED=true

RESEND_API_KEY=
FROM_EMAIL=noreply@wingconcept.com

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
STRIPE_SUCCESS_URL=https://wingconcept.com/checkout/exito
STRIPE_CANCEL_URL=https://wingconcept.com/checkout/cancelado

RUN_MIGRATIONS=true
