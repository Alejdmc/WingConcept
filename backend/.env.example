# WingConcept Backend — Variables de Entorno
# Equipo: ZomiDev
# IMPORTANTE: Copiar este archivo a .env y rellenar los valores
# NUNCA commitear el .env con valores reales no sea marica

# App
APP_NAME=WingConcept API
APP_VERSION=1.0.0
ENVIRONMENT=development        # development | staging | production
DEBUG=True
API_V1_PREFIX=/api/v1

# --- Servidor ---
HOST=0.0.0.0
PORT=8000

# BASE DE DATOS — Supabase PostgreSQL
# Panel: https://app.supabase.com → Settings → Database
# Formato: postgresql://[user]:[password]@[host]:[port]/[db] (se me olvida)
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres

# --- Supabase (Storage, Auth integrada) ---
# Panel: https://app.supabase.com → Settings → API
SUPABASE_URL=https://[PROJECT_ID].supabase.co
SUPABASE_SERVICE_KEY=eyJ...    # service_role key (admin, NO exponer al cliente)
SUPABASE_ANON_KEY=eyJ...       # anon key (pública)
SUPABASE_BUCKET_PRODUCTOS=productos
SUPABASE_BUCKET_MODELOS_3D=modelos3d

# REDIS — Cache, sesiones, rate limiting, carrito anónimo
# Docker: redis:6379 | Producción: Redis Cloud o Upstash
REDIS_HOST=localhost            # local dev: localhost | Docker: redis (nombre del servicio)
REDIS_PORT=6379
REDIS_PASSWORD=                # Dejar vacío si no tiene contraseña
REDIS_DB=0
REDIS_CART_TTL=86400           # Segundos que vive el carrito anónimo (24h)
REDIS_CACHE_TTL=300            # Segundos de cache para productos (5min)

# JWT — Autenticación
# Generar SECRET_KEY con: openssl rand -hex 32
SECRET_KEY=CAMBIAR_POR_CLAVE_SEGURA_GENERADA_CON_OPENSSL
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# WOMPI
# Panel: https://comercios.wompi.co
# Docs: https://docs.wompi.co
# Modo sandbox: usar claves pub_test_ / prv_test_
# Modo producción: usar claves pub_prod_ / prv_prod_
WOMPI_BASE_URL=https://sandbox.wompi.co/v1   # Cambiar a https://production.wompi.co/v1 en prod
WOMPI_PUBLIC_KEY=pub_test_OBTENER_EN_PANEL_WOMPI
WOMPI_PRIVATE_KEY=prv_test_OBTENER_EN_PANEL_WOMPI
WOMPI_EVENTS_SECRET=OBTENER_EN_PANEL_WOMPI    # Para validar HMAC de webhooks
WOMPI_REDIRECT_URL=https://tudominio.com/checkout/confirmacion

# STRIPE (internacional)
# Panel: https://dashboard.stripe.com
# Docs: https://stripe.com/docs/api
# Test keys empiezan con sk_test_ / pk_test_
# Live keys empiezan con sk_live_ / pk_live_
STRIPE_SECRET_KEY=sk_test_OBTENER_EN_DASHBOARD_STRIPE
STRIPE_PUBLISHABLE_KEY=pk_test_OBTENER_EN_DASHBOARD_STRIPE
STRIPE_WEBHOOK_SECRET=whsec_OBTENER_EN_DASHBOARD_STRIPE  # CLI: stripe listen --print-secret
STRIPE_CURRENCY=usd             # Moneda por defecto para Stripe
STRIPE_SUCCESS_URL=https://tudominio.com/checkout/exitoso
STRIPE_CANCEL_URL=https://tudominio.com/checkout/cancelado

# RESEND — Email transaccional
# Panel: https://resend.com/overview
# Docs: https://resend.com/docs
# Requiere verificar dominio en DNS
RESEND_API_KEY=re_OBTENER_EN_PANEL_RESEND
FROM_EMAIL=noreply@wingconcept.com
FROM_NAME=WingConcept

# CORS — Orígenes permitidos (separados por comas)
ALLOWED_ORIGINS=http://localhost:3000,https://wingconcept.com,https://www.wingconcept.com

# LOGGING
# Niveles: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# UPLOADS / STORAGE
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_MODEL_TYPES=model/gltf-binary,model/gltf+json,application/octet-stream

