# ============================================================
# WingConcept Backend — PRODUCCIÓN
# ⚠️ IMPORTANTE: Este archivo es plantilla para producción
# ============================================================

# App
APP_NAME=WingConcept API
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=False
API_V1_PREFIX=/api/v1

# Servidor
HOST=0.0.0.0
PORT=8000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SEGURIDAD CRÍTICA — GENERAR VALORES ÚNICOS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# JWT Secret (generar con: openssl rand -hex 32)
SECRET_KEY=REEMPLAZAR_CON_VALOR_SEGURO_DE_32_CARACTERES_MINIMO
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis Password (generar con: openssl rand -hex 16)
REDIS_PASSWORD=REEMPLAZAR_CON_PASSWORD_SEGURO

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# BASE DE DATOS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Opción A: Supabase PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres

# Opción B: Servidor propio PostgreSQL
# DATABASE_URL=postgresql+asyncpg://[user]:[password]@[host]:[port]/[database]

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SUPABASE (si se usa)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

SUPABASE_URL=https://[PROJECT_ID].supabase.co
SUPABASE_SERVICE_KEY=eyJ...    # service_role key
SUPABASE_ANON_KEY=eyJ...       # anon key
SUPABASE_BUCKET_PRODUCTOS=productos
SUPABASE_BUCKET_MODELOS_3D=modelos3d

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# REDIS — PRODUCCIÓN
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Docker: redis | Redis Cloud: redis-xxxxx.cloud.redislabs.com
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CONFIGURAR_ARRIBA
REDIS_DB=0
REDIS_CART_TTL=86400
REDIS_CACHE_TTL=300

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# STRIPE — PRODUCCIÓN
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

STRIPE_SECRET_KEY=sk_live_OBTENER_EN_DASHBOARD
STRIPE_PUBLISHABLE_KEY=pk_live_OBTENER_EN_DASHBOARD
STRIPE_WEBHOOK_SECRET=whsec_OBTENER_EN_DASHBOARD
STRIPE_CURRENCY=usd
STRIPE_SUCCESS_URL=https://wingconcept.com/checkout/exitoso
STRIPE_CANCEL_URL=https://wingconcept.com/checkout/cancelado

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# RESEND — EMAIL PRODUCCIÓN
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

RESEND_API_KEY=re_OBTENER_EN_PANEL
FROM_EMAIL=noreply@wingconcept.com
FROM_NAME=WingConcept
EMAIL_VERIFY_EXPIRE_HOURS=24

# ⚠️ ACTIVAR EN PRODUCCIÓN
REQUIRE_EMAIL_VERIFIED=true

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CORS Y HOSTS — PRODUCCIÓN
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ⚠️ CAMBIAR AL DOMINIO REAL
ALLOWED_ORIGINS=https://wingconcept.com,https://www.wingconcept.com
FRONTEND_URL=https://wingconcept.com
ALLOWED_HOSTS=wingconcept.com,www.wingconcept.com

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LOGGING Y OBSERVABILIDAD
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

LOG_LEVEL=WARNING

# Sentry (opcional pero recomendado)
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
# SENTRY_ENVIRONMENT=production

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# STORAGE
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_MODEL_TYPES=model/gltf-binary,model/gltf+json,application/octet-stream

